# AI News Daily Digest — Configuration
# Copy this file to .env and fill in your values
# IMPORTANT: chmod 600 .env to protect your secrets

# Required: Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_CHAT_ID=your-chat-or-group-id

# Optional: LLM settings
# Explicit LLM_* overrides agent defaults. If omitted, the app will inherit
# AGENT_PRIMARY_PROVIDER / AGENT_PRIMARY_MODEL when available, else fall back to Ollama.
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1:8b
LLM_API_BASE=
LLM_TIMEOUT=120
LLM_MAX_TOKENS=1800

# Provider API keys (set only for the provider you use)
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# Legacy Ollama settings still supported
OLLAMA_MODEL=llama3.1:8b
OLLAMA_HOST=http://localhost:11434

# Optional: Delivery time (24h format, default: 7)
DELIVERY_HOUR=7

# Optional: Archive + retention
RETENTION_DAYS=30
DATA_DIR=./data

# Optional: Logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
