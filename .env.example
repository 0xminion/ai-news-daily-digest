# Telegram (only needed when OUTPUT_MODE=telegram)
TELEGRAM_BOT_TOKEN=***
TELEGRAM_CHAT_ID=replace-me
# TELEGRAM_DESTINATIONS_JSON=[{"name":"main","chat_id":"123456789","bot_token":"replace-me","profile":"default"}]

# Output mode: "stdout" to print to console, "telegram" to deliver via Telegram.
# Default is "stdout" so new users can run the digest immediately without setting up a bot.
OUTPUT_MODE=stdout

# LLM — use a model with at least 200k context
# LLM_PROVIDER=ollama
# LLM_MODEL=kimi-k2.6:cloud
# LLM_API_BASE=
# LLM_CONTEXT_LIMIT=
# Set OPENAI_API_KEY when LLM_PROVIDER=openai
# Set OPENROUTER_API_KEY when LLM_PROVIDER=openrouter
# Set ANTHROPIC_API_KEY when LLM_PROVIDER=anthropic
OLLAMA_HOST=http://localhost:11434
LLM_TIMEOUT=120
LLM_MAX_TOKENS=1800

# Storage / behavior
DATA_DIR=./data
RETENTION_DAYS=30
CROSS_DAY_DEDUP_DAYS=7
TREND_LOOKBACK_DAYS=7
RESEARCH_SIGNALS_COUNT=5
LOG_LEVEL=INFO
