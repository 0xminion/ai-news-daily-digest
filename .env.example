# Telegram (only needed when OUTPUT_MODE=telegram)
TELEGRAM_BOT_TOKEN=***
TELEGRAM_CHAT_ID=replace-me
# TELEGRAM_DESTINATIONS_JSON=[{"name":"main","chat_id":"123456789","bot_token":"replace-me","profile":"default"}]

# Output mode: "stdout" to print to console, "telegram" to deliver via Telegram.
# Default is "stdout" so new users can run the digest immediately without setting up a bot.
OUTPUT_MODE=stdout

# ---------------------------------------------------------------------------
# LLM Provider
# ---------------------------------------------------------------------------
# Default: "agent" — the running agent (you) generates the summary.
# No API keys, no Ollama setup, no external dependencies.
#
# To use an external LLM instead, uncomment one of the blocks below:
#
# Ollama (local):
#   LLM_PROVIDER=ollama
#   LLM_MODEL=minimax-m2.7:cloud
#   OLLAMA_HOST=http://localhost:11434
#
# OpenAI / OpenRouter / Anthropic:
#   LLM_PROVIDER=openrouter
#   LLM_MODEL=moonshotai/kimi-k2.6
#   LLM_API_BASE=https://openrouter.ai/api/v1
#   Set OPENROUTER_API_KEY or OPENAI_API_KEY or ANTHROPIC_API_KEY
#
# When using the "agent" provider, you can optionally pass a pre-generated
# summary via the AGENT_DIGEST_JSON environment variable (JSON string).
# ---------------------------------------------------------------------------
LLM_PROVIDER=agent
LLM_MODEL=agent

# Storage / behavior
DATA_DIR=./data
RETENTION_DAYS=30
CROSS_DAY_DEDUP_DAYS=7
TREND_LOOKBACK_DAYS=7
RESEARCH_SIGNALS_COUNT=5
LOG_LEVEL=INFO
