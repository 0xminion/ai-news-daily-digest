# AI News Daily Digest — Configuration
# Copy this file to .env and fill in your values
# IMPORTANT: chmod 600 .env to protect your secrets

# Required: Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_CHAT_ID=your-chat-or-group-id
# Or use multi-destination delivery with JSON:
# TELEGRAM_DESTINATIONS_JSON=[{"name":"main","chat_id":"-1001234567890","profile":"default"},{"name":"group2","chat_id":"-1009876543210","bot_token":"optional-other-bot-token","profile":"compact"}]

# Optional: LLM settings
# Explicit LLM_* overrides agent defaults. If omitted, the app will inherit
# AGENT_PRIMARY_PROVIDER / AGENT_PRIMARY_MODEL when available, else fall back to Ollama.
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1:8b
LLM_API_BASE=
LLM_TIMEOUT=120
LLM_MAX_TOKENS=1800

# Provider API keys (set only for the provider you use)
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# Legacy Ollama settings still supported
OLLAMA_MODEL=llama3.1:8b
OLLAMA_HOST=http://localhost:11434

# Optional: Delivery time (24h format, default: 7)
DELIVERY_HOUR=7

# Optional: Archive + retention
RETENTION_DAYS=30
CROSS_DAY_DEDUP_DAYS=7
TREND_LOOKBACK_DAYS=7
DATA_DIR=./data

# Optional: Hacker News signals (enrichment-only, never standalone)
HN_ENABLED=true
HN_MIN_POINTS=15
HN_MIN_COMMENTS=5
HN_MAX_STORIES=20
HN_SIGNAL_WINDOW_HOURS=36

# Optional: Orthogonal signal layers
ORTHOGONAL_SIGNALS_ENABLED=true

# Optional: Weekly highlights sizing
WEEKLY_HIGHLIGHTS_COUNT=7
WEEKLY_DIRECTIONS_COUNT=4
WEEKLY_FOCUS_COUNT=2
WEEKLY_QUESTIONS_COUNT=6

# Optional: follow-builders v2 integration room
FOLLOW_BUILDERS_ENABLED=false
FOLLOW_BUILDERS_FEEDS_JSON=[]
FOLLOW_BUILDERS_PROMPT_STYLE=builders
FOLLOW_BUILDERS_SCHEMA_VERSION=v1

# Optional: Logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
